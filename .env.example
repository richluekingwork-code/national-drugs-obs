# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.sevalla.app,your-custom-domain.com
CSRF_TRUSTED_ORIGINS=https://your-app.sevalla.app,https://your-custom-domain.com

# Database (Sevalla provides DATABASE_URL for PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis (Sevalla provides this)
CELERY_BROKER_URL=redis://user:password@host:6379/0
CELERY_RESULT_BACKEND=redis://user:password@host:6379/0

# CORS (set your frontend domain if separate from backend)
CORS_ALLOWED_ORIGINS=https://your-app.sevalla.app,https://your-custom-domain.com
